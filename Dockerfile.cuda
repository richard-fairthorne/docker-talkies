# syntax=docker/dockerfile:1.7
#
# CUDA image — NVIDIA CUDA 12.6 base + PyTorch CUDA + nemo_toolkit[asr] +
# faster-whisper + kokoro (TTS). Serves whisper variants, parakeet-tdt, all
# three canary models (180m-flash, 1b-flash, canary-qwen-2.5b) for ASR, plus
# kokoro-82m TTS via /v1/audio/speech.
#
# We use the CUDA runtime base (not cudnn-devel) and let pytorch's bundled
# CUDA libs handle the rest. nemo_toolkit[asr] pulls flash-attn etc. on
# install — keep build-essential in the builder stage.
#
# Supply chain:
#   Lightweight runtime deps: uv sync --frozen from uv.lock (hash-verified).
#   Heavy ML stack: uv pip install --require-hashes from requirements-heavy-cuda.txt
#   (generated by scripts/compile-heavy-deps.sh — run `make compile-heavy` to refresh).
#
# Version rationale + open-CVE threat model in scripts/heavy-deps-cuda.in.
# Known open CVEs (threat-modelled; not exploitable in this app):
#   PYSEC-2026-139 (torch pt2 load): we don't torch.load() untrusted files.
#   GHSA-75m9-98v2-hjpm (PL load_from_checkpoint): we don't call it.
#   GHSA-69w3-r845-3855 / PYSEC-2025-217 (transformers Trainer): we don't train.

FROM python:3.12-slim-bookworm@sha256:d193c6f51a7dbd10395d6328de3a7edb0516fb0608ca138036576f574c3e07d2 AS builder

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    UV_COMPILE_BYTECODE=1 \
    UV_LINK_MODE=copy \
    UV_PROJECT_ENVIRONMENT=/opt/venv

RUN apt-get update && apt-get install -y --no-install-recommends \
        build-essential \
        git \
        curl \
        cmake \
    && rm -rf /var/lib/apt/lists/*

COPY --from=ghcr.io/astral-sh/uv:0.11.15@sha256:e590846f4776907b254ac0f44b5b380347af5d90d668138ca7938d1b0c2f98d3 /uv /usr/local/bin/uv

WORKDIR /app

# 1) Lightweight runtime deps — frozen install from uv.lock, hash-verified.
COPY pyproject.toml uv.lock ./
COPY src ./src
RUN --mount=type=cache,target=/root/.cache/uv \
    uv venv /opt/venv && \
    uv sync --frozen --no-dev

# 2) Heavy ML deps — CUDA torch + nemo_toolkit[asr] + qwen3-tts. Hash-locked.
COPY requirements-heavy-cuda.txt ./
RUN --mount=type=cache,target=/root/.cache/uv \
    uv pip install --python /opt/venv/bin/python \
        --no-config \
        --require-hashes \
        --no-deps \
        --extra-index-url https://download.pytorch.org/whl/cu126 \
        --index-strategy unsafe-best-match \
        -r requirements-heavy-cuda.txt

# -----------------------------------------------------------------------------
# parakeet.cpp build stage — produces libparakeet.so used by the parakeet_cpp
# backend (NVIDIA Parakeet TDT/CTC/RNNT + Nemotron-3.5-ASR via ggml/C++). MIT.
# Pinned by full commit SHA (tags are mutable on this repo). Built CPU-only
# (no -DPARAKEET_GGML_CUDA) so the same .so works in both CPU and CUDA images
# without dragging the CUDA toolchain through the build context. Nemotron-3.5
# runs ~2-3x faster on CPU here than NeMo's PyTorch path anyway; if you want
# GPU offload for parakeet.cpp specifically, rebuild this stage on a CUDA
# devel base with -DPARAKEET_GGML_CUDA=ON + a pinned CUDA_ARCHS list.
FROM python:3.12-slim-bookworm@sha256:d193c6f51a7dbd10395d6328de3a7edb0516fb0608ca138036576f574c3e07d2 AS parakeet-builder

ARG PARAKEET_CPP_SHA=e270af73b94c9a5c37ec516230219ed4580e1db6

RUN apt-get update && apt-get install -y --no-install-recommends \
        build-essential \
        cmake \
        git \
        ca-certificates \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /src
RUN git clone https://github.com/mudler/parakeet.cpp /src/parakeet.cpp \
    && cd /src/parakeet.cpp \
    && git checkout "${PARAKEET_CPP_SHA}" \
    && git submodule update --init --recursive

WORKDIR /src/parakeet.cpp
RUN cmake -B build \
        -DPARAKEET_SHARED=ON \
        -DPARAKEET_BUILD_CLI=ON \
        -DPARAKEET_BUILD_TESTS=OFF \
        -DGGML_NATIVE=OFF \
    && cmake --build build -j "$(nproc)" \
    && mkdir -p /out/lib /out/bin /out/include \
    && cp -P build/libparakeet.so* /out/lib/ \
    && cp -P build/third_party/ggml/src/libggml*.so* /out/lib/ \
    && cp build/examples/cli/parakeet-cli /out/bin/ \
    && cp include/parakeet_capi.h /out/include/ \
    && cp include/parakeet.h /out/include/

# -----------------------------------------------------------------------------
# Runtime — uses CUDA 12.6 runtime on ubuntu24.04 (python3.12 in base repos).
FROM nvidia/cuda:12.6.3-runtime-ubuntu24.04@sha256:92906d87596d638d35015c6353053121bd299d25943b875763321653884ba924 AS runtime

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PATH="/opt/venv/bin:$PATH" \
    PYTHONPATH=/app/src \
    TZ=UTC \
    TALKIES_DEVICE=cuda \
    TALKIES_MODELS_FILE=/app/models.json \
    TALKIES_DATA_DIR=/data \
    HF_HOME=/data/hf \
    HF_HUB_OFFLINE=1 \
    PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True \
    TORCHINDUCTOR_CACHE_DIR=/tmp/torch_inductor \
    LD_LIBRARY_PATH=/opt/venv/lib/python3.12/site-packages/nvidia/cudnn/lib:/opt/venv/lib/python3.12/site-packages/nvidia/cublas/lib \
    DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
        python3.12 \
        python3-pip \
        ffmpeg \
        libsndfile1 \
        libgomp1 \
        ca-certificates \
        espeak-ng \
    && rm -rf /var/lib/apt/lists/* \
    && (userdel -r ubuntu 2>/dev/null || true) \
    && useradd -u 1000 --create-home --shell /bin/bash talkies \
    && mkdir -p /data \
    && chown talkies:talkies /data \
    && ln -sf /usr/bin/python3.12 /usr/local/bin/python3 \
    && ln -sf /usr/bin/python3.12 /usr/local/bin/python

WORKDIR /app

COPY --from=builder /opt/venv /opt/venv

# parakeet.cpp shared lib + ggml runtime + CLI for the parakeet_cpp ASR backend.
# libparakeet.so is dlopen'd via ctypes from src/talkies/models/parakeet_cpp.py;
# libggml*.so are transitive deps the loader resolves via LD_LIBRARY_PATH;
# parakeet-cli is shipped for ops debugging (manual transcription).
COPY --from=parakeet-builder /out/lib/ /opt/parakeet/lib/
COPY --from=parakeet-builder /out/bin/parakeet-cli /usr/local/bin/parakeet-cli
ENV LD_LIBRARY_PATH="/opt/parakeet/lib:${LD_LIBRARY_PATH}"
ENV TALKIES_PARAKEET_CPP_LIB=/opt/parakeet/lib/libparakeet.so

COPY --chown=talkies:talkies src ./src
COPY --chown=talkies:talkies pyproject.toml ./
COPY --chown=talkies:talkies models.json /app/models.json
COPY --chown=talkies:talkies voices/qwen3/ /opt/talkies/qwen3-voices/
COPY --chown=talkies:talkies entrypoint.sh /usr/local/bin/talkies-entrypoint
RUN sed -i 's/\r$//' /usr/local/bin/talkies-entrypoint \
    && chmod +x /usr/local/bin/talkies-entrypoint

USER talkies

EXPOSE 8000

HEALTHCHECK --interval=30s --timeout=5s --start-period=30s --retries=3 \
    CMD python -c "import urllib.request,sys; sys.exit(0 if urllib.request.urlopen('http://127.0.0.1:8000/healthz').status==200 else 1)" || exit 1

ENTRYPOINT ["/usr/local/bin/talkies-entrypoint"]
